# Curador de Rarezas v2 — Variables de entorno

# IA: Se elige automáticamente por prioridad (el primero con key gana)
# 1. Groq (GRATIS, rápido, Llama 3.3 70B) — https://console.groq.com
GROQ_API_KEY=
# 2. OpenRouter (GRATIS, modelos free) — https://openrouter.ai
OPENROUTER_API_KEY=
# 3. DeepSeek (barato) — https://platform.deepseek.com
DEEPSEEK_API_KEY=
# 4. OpenAI (fallback, de pago) — https://platform.openai.com
OPENAI_API_KEY=

# Búsqueda web real (opcional pero recomendado)
# Regístrate en https://serpapi.com — 100 búsquedas/mes gratis
SERPAPI_KEY=

# Newsletter
BREVO_API_KEY=